{
  "$schema": "http://json-schema.org/draft-04/schema",
  "type": "object",
  "required": [
    "data",
    "meta"
  ],
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "required_string",
          "required_object"
        ],
        "additionalProperties": false,
        "properties": {
          "required_string": { "type": "string" },
          "optional_nullable_string": { "type": ["string", "null"] },
          "required_object": {
            "type": "object",
            "required": [
              "required_nested_object"
            ],
            "properties": {
              "required_nested_object": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "nested_optional_int": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}