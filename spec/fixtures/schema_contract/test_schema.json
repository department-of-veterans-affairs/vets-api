{
  "$schema": "http://json-schema.org/draft-04/schema",
  "type": "object",
  "required": [
    "data",
    "meta"
  ],
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "identifier",
          "extension"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "identifier": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "system": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          },
          "extension": {
            "type": "object",
            "required": [
              "cc_location"
            ],
            "properties": {
              "cc_location": {
                "type": "object",
                "properties": {
                  "address": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "meta": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "errors": {
            "type":"array",
            "items": {
              "type": "object",
              "properties": {
                "detail": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}